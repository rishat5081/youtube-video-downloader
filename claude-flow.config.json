{
  "name": "youtube-downloader",
  "namespace": "youtube-downloader",
  "topology": "ring",
  "description": "Electron desktop app for downloading YouTube videos/audio via yt-dlp + ffmpeg",
  "agents": {
    "teamFile": ".agents/team.json",
    "agentDocs": ".claude/agents/"
  },
  "routing": {
    "rules": [
      { "pattern": "bug-fix", "agent": "coder", "priority": "high" },
      { "pattern": "feature", "agent": "planner", "priority": "normal" },
      { "pattern": "security", "agent": "security-auditor", "priority": "critical" },
      { "pattern": "testing", "agent": "tester", "priority": "normal" },
      { "pattern": "review", "agent": "reviewer", "priority": "normal" },
      { "pattern": "performance", "agent": "performance", "priority": "normal" },
      { "pattern": "release", "agent": "release-manager", "priority": "normal" },
      { "pattern": "issue", "agent": "issue-tracker", "priority": "normal" },
      { "pattern": "quality", "agent": "code-analyzer", "priority": "normal" },
      { "pattern": "deploy", "agent": "production-validator", "priority": "high" },
      { "pattern": "ci", "agent": "devops", "priority": "normal" },
      { "pattern": "architecture", "agent": "architect", "priority": "normal" }
    ]
  },
  "memory": {
    "namespace": "youtube-downloader",
    "isolation": true,
    "persistence": true
  },
  "ci": {
    "test": "pnpm test",
    "lint": "pnpm lint",
    "typecheck": "pnpm check",
    "build": "pnpm build",
    "format": "pnpm format",
    "validate": "pnpm validate"
  }
}
